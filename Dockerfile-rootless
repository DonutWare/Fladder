FROM ghcr.io/nginxinc/nginx-unprivileged:stable-alpine-slim

EXPOSE 8080

ENV BASE_URL=""
ENV SEERR_URL=""
ENV HIDE_PASSWORD_LOGIN=""
ENV SEERR_CUSTOM_HEADERS=""

USER root
RUN apk add --no-cache jq
COPY build/web /usr/share/nginx/html
COPY docker/docker-entrypoint.sh /docker-entrypoint.sh
COPY docker/nginx.conf.template /docker-nginx.conf.template

RUN chmod +x /docker-entrypoint.sh && \
    chown -R nginx:nginx /usr/share/nginx/html && \
    sed -i 's|__PORT__|8080|g' /docker-nginx.conf.template

CMD ["/docker-entrypoint.sh"]
